<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DemoTape.App.UI.BackgroundPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DemoTape.App.UI">

    <Grid x:Name="Root" Padding="16" RowSpacing="12"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose Background (used in region mode)"
                   Style="{ThemeResource TitleTextBlockStyle}" />

        <GridView Grid.Row="1" x:Name="Gallery" SelectionMode="Single"
                  IsItemClickEnabled="True" ItemClick="OnItemClick">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:BackgroundItem">
                    <Border CornerRadius="8" Margin="4">
                        <Image Width="176" Height="104" Stretch="UniformToFill" Source="{x:Bind Image}" />
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <TextBlock x:Name="Selected" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Button Content="Custom Image…" Click="OnCustom" />
        </StackPanel>
    </Grid>
</Window>
