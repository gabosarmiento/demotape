<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DemoTape.App.UI.RegionSelectorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="Root" Background="#66000000">
        <Canvas x:Name="Layer">
            <Border x:Name="SelRect" BorderBrush="White" BorderThickness="2"
                    Background="#18FFFFFF" Visibility="Collapsed" />
            <TextBlock x:Name="DimText" Foreground="White" FontSize="13" FontWeight="SemiBold"
                       Visibility="Collapsed" />
        </Canvas>
        <TextBlock Text="Drag to select an area  ·  release to confirm  ·  Esc to cancel"
                   Foreground="#E6FFFFFF" FontSize="18" FontWeight="Medium"
                   HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
    </Grid>
</Window>
