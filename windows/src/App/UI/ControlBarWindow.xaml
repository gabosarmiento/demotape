<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DemoTape.App.UI.ControlBarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DemoTape.App.UI">

    <Grid x:Name="Root" Background="#1C1C1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left drag grip -->
        <local:DragArea x:Name="LeftDrag" Grid.Column="0" Background="Transparent"
                        ToolTipService.ToolTip="Drag to move">
            <Border Padding="8,10">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76F;" FontSize="14" Foreground="#6A6A6E" />
            </Border>
        </local:DragArea>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <!-- Start / Stop -->
            <Button x:Name="RecordBtn" Click="OnRecord" Background="#22B0E6" Foreground="White"
                    CornerRadius="8" Padding="12,7" BorderThickness="0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse x:Name="RecDot" Width="12" Height="12" Fill="White" />
                    <TextBlock x:Name="RecLabel" Text="Start" FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <TextBlock x:Name="TimerText" Text="00:00" Foreground="White" FontSize="15"
                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0"
                       Visibility="Collapsed" />

            <Rectangle Width="1" Height="24" Fill="#3A3A3C" Margin="4,0" />

            <ToggleButton x:Name="MicBtn" Click="OnToggleMic" Background="Transparent"
                          BorderThickness="0" CornerRadius="8" Padding="8" ToolTipService.ToolTip="Microphone">
                <Grid Width="22" Height="22">
                    <FontIcon x:Name="MicIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE720;" FontSize="20" FontWeight="Bold" />
                    <Line x:Name="MicStrike" X1="2" Y1="20" X2="20" Y2="2" Stroke="#FF5A5A" StrokeThickness="2.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" />
                </Grid>
            </ToggleButton>
            <ToggleButton x:Name="CamBtn" Click="OnToggleCam" Background="Transparent"
                          BorderThickness="0" CornerRadius="8" Padding="8" ToolTipService.ToolTip="Webcam">
                <Grid Width="22" Height="22">
                    <FontIcon x:Name="CamIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE714;" FontSize="20" FontWeight="Bold" />
                    <Line x:Name="CamStrike" X1="2" Y1="20" X2="20" Y2="2" Stroke="#FF5A5A" StrokeThickness="2.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" />
                </Grid>
            </ToggleButton>

            <Rectangle Width="1" Height="24" Fill="#3A3A3C" Margin="4,0" />

            <Button x:Name="CancelBtn" Click="OnCancel" Background="Transparent" BorderThickness="0"
                    CornerRadius="8" Padding="8" ToolTipService.ToolTip="Cancel">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" FontSize="16" Foreground="#FF8A80" />
            </Button>
        </StackPanel>

        <!-- Right empty area is also draggable -->
        <local:DragArea x:Name="RightDrag" Grid.Column="2" Background="Transparent" />
    </Grid>
</Window>
