<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DemoTape.App.UI.WebPublishWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:DemoTape.App.UI">

    <Grid x:Name="Root" Padding="24" RowSpacing="16"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Web Publish" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="{Binding SourceName}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Quality (select one or more)"
                   Style="{ThemeResource BodyStrongTextBlockStyle}" />

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Tiers}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="16" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Grid.Row="3" Text="{Binding Estimate}"
                   Style="{ThemeResource BodyTextBlockStyle}" />

        <TextBlock Grid.Row="4" TextWrapping="Wrap"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="Use 720p only when the demo has small UI text or code. Selecting several tiers builds a responsive video that serves the right size per screen." />

        <ProgressBar Grid.Row="5" VerticalAlignment="Top" Margin="0,8,0,0"
                     Minimum="0" Maximum="1" Value="{Binding Progress}"
                     Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <ProgressRing IsActive="{Binding IsExporting}" Width="20" Height="20" />
            <Button Content="Export" Style="{ThemeResource AccentButtonStyle}"
                    Command="{Binding ExportCommand}" />
        </StackPanel>
    </Grid>
</Window>
