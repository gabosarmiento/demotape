<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DemoTape.App.UI.BrandingSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel Padding="28" Spacing="14" MaxWidth="480">
            <TextBlock Text="Branding" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Bake your logo into the styled recording." Opacity="0.7" FontSize="12" />

            <CheckBox x:Name="EnableBox" Content="Enable branding" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Image x:Name="Preview" Width="72" Height="72" Stretch="Uniform" />
                <StackPanel VerticalAlignment="Center" Spacing="6">
                    <Button Content="Choose Image…" Click="OnChooseImage" />
                    <TextBlock x:Name="PathLabel" Text="No image chosen" Opacity="0.7" FontSize="11"
                               TextTrimming="CharacterEllipsis" MaxWidth="320" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Position" Width="90" VerticalAlignment="Center" />
                <ComboBox x:Name="PositionCombo" MinWidth="180">
                    <x:String>TopLeft</x:String>
                    <x:String>TopRight</x:String>
                    <x:String>BottomLeft</x:String>
                    <x:String>BottomRight</x:String>
                </ComboBox>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Opacity" />
                <Slider x:Name="OpacitySlider" Minimum="10" Maximum="100" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Size (% of width)" />
                <Slider x:Name="ScaleSlider" Minimum="4" Maximum="40" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="OnCancel" />
                <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="OnSave" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
