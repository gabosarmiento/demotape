<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>DemoTape.App</RootNamespace>
    <AssemblyName>DemoTape</AssemblyName>
    <UseWinUI>true</UseWinUI>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <!-- Unpackaged (no MSIX) app: run the .exe directly, like the macOS build. -->
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <EnableMsixTooling>true</EnableMsixTooling>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!--
    The portable sub-projects (Domain, Services, ViewModels) physically live under this folder
    to honor the /src/App/<layer> layout. Because this WinUI project is rooted at src/App, we must
    stop it from globbing those sibling project folders (which would double-compile their sources
    and generated files). They are consumed via ProjectReference instead.
  -->
  <ItemGroup>
    <Compile Remove="Domain\**\*.cs" />
    <Compile Remove="Services\**\*.cs" />
    <Compile Remove="ViewModels\**\*.cs" />
    <Page Remove="Domain\**\*.xaml;Services\**\*.xaml;ViewModels\**\*.xaml" />
    <Content Remove="Domain\**;Services\**;ViewModels\**" />
    <None Remove="Domain\**;Services\**;ViewModels\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.6.240923002" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.1742" />
    <PackageReference Include="H.NotifyIcon.WinUI" Version="2.1.3" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
    <PackageReference Include="Microsoft.Graphics.Win2D" Version="1.2.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="Domain\DemoTape.Domain.csproj" />
    <ProjectReference Include="Services\DemoTape.Services.csproj" />
    <ProjectReference Include="ViewModels\DemoTape.ViewModels.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Bundled gradient backgrounds (copied from the macOS Resources/background folder). -->
    <Content Include="Assets\Backgrounds\*.png" CopyToOutputDirectory="PreserveNewest" />
    <!-- Tray icon (multi-resolution .ico, most reliable for the notification area). -->
    <Content Include="Assets\demotape.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\trayicon.png" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
