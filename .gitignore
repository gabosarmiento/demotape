# Swift Package Manager build output
.build/
Package.resolved

# Packaged app bundle (produced by build-app.sh)
*.app/

# Distributable disk images (produced by make-dmg.sh)
dist/
*.dmg

# Signing artifacts
*.p12
*.pem

# macOS
.DS_Store

# Editor
.vscode/
*.xcuserstate
xcuserdata/

# Local recordings / exports (should never be committed)
*.mov
*.mp4
*.events.json

# Local verification scratch dir (live API probes, secrets via env — never commit)
.verify/

# Playwright demo driver (external Node tool — deps not committed)
tools/demo-driver/node_modules/
tools/demo-driver/driver.log

# Python bytecode from the local TTS shim
__pycache__/
*.pyc
